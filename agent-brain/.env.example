# Valis Agent Brain — Environment Configuration
# Copy this to .env and fill in your API keys

# WebSocket connection to Minecraft server
VALIS_WS_HOST=localhost
VALIS_WS_PORT=9876

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Ollama (local models)
# No API key needed — set LLM provider to "ollama" in agent config
# OLLAMA_BASE_URL=http://localhost:11434

# Default LLM provider: openai, anthropic, or ollama
VALIS_DEFAULT_LLM=openai
VALIS_DEFAULT_MODEL=gpt-4o

# Data storage
VALIS_DATA_DIR=./data

# Logging
VALIS_LOG_LEVEL=INFO
